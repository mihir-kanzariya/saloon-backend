# ============================================
# Saloon Backend - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---------- Server ----------
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ---------- Database (PostgreSQL) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saloon_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ---------- JWT ----------
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=90d

# ---------- OTP ----------
# true = test OTP (always 1111), false = real MSG91
USE_TEST_OTP=true

# ---------- MSG91 (OTP) ----------
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=SALOON

# ---------- Razorpay (Route) ----------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_ACCOUNT_NUMBER=                          # RazorpayX account (for incentive payouts)

# ---------- Supabase (Realtime Chat) ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------- Firebase (Push Notifications) ----------
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ---------- File Upload ----------
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# ---------- App Config ----------
OTP_EXPIRY_MINUTES=5
BOOKING_ADVANCE_DAYS=30
PLATFORM_COMMISSION_PERCENT=10
MIN_WITHDRAWAL_AMOUNT=500

# ---------- Settlement & Payouts ----------
SETTLEMENT_CRON=0 2 * * 3                         # Wednesday 2 AM
SETTLEMENT_BUFFER_HOURS=72                         # Buffer before settlement eligibility
MIN_TRANSFER_AMOUNT=100                            # Minimum transfer in paise (₹1)
REFUND_WINDOW_HOURS=72                             # Refund allowed within this window
MAX_BOOKINGS_PER_SALON_PER_DAY=50                  # Fraud control
INCENTIVE_BOOKING_THRESHOLD=150                    # Monthly bookings for ₹10K bonus
INCENTIVE_AMOUNT=10000                             # Bonus amount in INR
RUN_CRON=true                                      # Set false for multi-instance

# ---------- CORS ----------
CORS_ORIGIN=*

# ---------- Branding ----------
APP_NAME=HeloHair
APP_TAGLINE=Never wait at a salon again
LOGO_URL=
PRIMARY_COLOR=#1F6A63
SUPPORT_EMAIL=support@helohair.com
MAX_BOOKING_AMOUNT=100000
